# Импортируем необходимые модули Python
import pandas as pd
from google.cloud import bigquery

# Создаем клиента BigQuery
client = bigquery.Client(project='PROJECT_ID')

sql_query = """
-- Цель: Чтобы быстрее считать количество POI в конкретном радиусе, подготовим таблицу, где для каждого гекса известны все гексы в этом радиусе.
CREATE TABLE `urban-access-bot.bot_geo.hex_neighbors_kl` AS (
WITH source_hexes AS (
  SELECT
    index,
    ST_CENTROID(geometry) AS centroid
  FROM `urban-access-bot.bot_geo.h3_10res_london_kl`
),
filtered_pairs AS (
  SELECT
    s1.index AS src_index,
    s2.index AS dst_index,
    ST_DISTANCE(s1.centroid, s2.centroid) AS distance_meters
  FROM source_hexes s1
  INNER JOIN source_hexes s2
  ON ST_DWITHIN(s1.centroid, s2.centroid, 1200) -- фильтруем перед расчетом расстояний исходя из максимального радиуса
  WHERE s1.index <> s2.index
),
-- Собираем гексы в пределах 400 метров
neighbors_400m AS (
  SELECT
    src_index,
    dst_index AS hex,
    400 AS distance
  FROM filtered_pairs
  WHERE distance_meters <= 400
  ORDER BY src_index
),
-- Собираем гексы в пределах 800 метров
neighbors_800m AS (
  SELECT
    src_index,
    dst_index AS hex,
    800 AS distance
  FROM filtered_pairs
  WHERE distance_meters <= 800
),
-- Собираем гексы в пределах 1200 метров
neighbors_1200m AS (
  SELECT
    src_index,
    dst_index AS hex,
    1200 AS distance
  FROM filtered_pairs
  WHERE distance_meters <= 1200
)
(SELECT *
FROM neighbors_400m
ORDER BY src_index)
UNION ALL
(SELECT *
FROM neighbors_800m
ORDER BY src_index)
UNION ALL
(SELECT *
FROM neighbors_1200m
ORDER BY src_index)
);
"""

df = client.query(sql_query).to_dataframe() # Получаем результат в DataFrame Pandas
display(df)
